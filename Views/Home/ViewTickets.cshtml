
@model IEnumerable<RaiseTickets>
@{
    ViewData["Title"] = "ViewTicket";
}
<div class="main-content-inner">
	<div class="breadcrumbs ace-save-state" id="breadcrumbs">
		<ul class="breadcrumb">
			<li>
				<i class="ace-icon fa fa-home home-icon"></i>
				<a href="#">Home</a>
			</li>

			<li>
				<a href="#">Tickets View</a>
			</li>
		</ul><!-- /.breadcrumb -->

		<div class="nav-search" id="nav-search">
			<form class="form-search">
				<span class="input-icon">
					<input type="text" placeholder="Search ..." class="nav-search-input" id="nav-search-input" autocomplete="off" />
					<i class="ace-icon fa fa-search nav-search-icon"></i>
				</span>
			</form>
		</div><!-- /.nav-search -->
	</div>
	<div class="page-content">
		<div class="row">
			<div class="col-xs-12">
				<h3 class="header smaller lighter blue">Tickets</h3>

				<div class="clearfix">
					<div class="pull-right tableTools-container"></div>
				</div>
				<div class="table-header">
					Tickets Info
				</div>

				<!-- div.table-responsive -->
				<!-- div.dataTables_borderWrap -->
				<div>
					<table id="dynamic-table" class="table table-striped table-bordered table-hover">
						<thead>
							<tr>
								<td></td>
								<th><i class="fa fa-calendar"></i> Date</th>
								<th><i class="fa fa-user"></i> Employee</th>
								<th><i class="fa fa-sticky-note-o"></i> Query</th>

								<th>
									<i class="ace-icon fa fa-check bigger-110 hidden-480"></i>
									Type
								</th>
								<th class="hidden-480"><i class="fa fa-sticky-note-o"></i> Status</th>

								<th> <i class="fa fa-sticky-note-o"></i> Answer</th>
								<th> <i class="fa fa-calendar"></i> Answer Date</th>

							</tr>
						</thead>
						@foreach (var tickets in Model)
						{
							<tbody>
								<tr>
									@if (tickets.Status == "Complete")
									{
										<td></td>

									}
									else
									{
										<td><form asp-action="SelectAnswer"><input name="ticket_id" type="hidden" value="@tickets.Id" /><button class="btn btn-primary btn-sm" type="submit"><i class="fa fa-angellist"></i> Answer</button></form> </td>

									}
									<td>
										@tickets.Created_On
									</td>
									<td>@tickets.Employee_Id</td>
									<td>@Html.Raw(@tickets.Query)</td>
									<td class="hidden-480">@tickets.Type</td>
									<td class="hidden-480">
										@if (tickets.Status == "Pending")
										{
											<span class="label label-sm label-inverse">@tickets.Status</span>

										}
										else if (tickets.Status == "Active")
										{
											<span class="label label-sm label-success">@tickets.Status</span>

										}
										else if (tickets.Status == "Complete")
										{
											<span class="label label-sm label-info">@tickets.Status</span>
										}
									</td>

									<td>@Html.Raw(@tickets.Answer)</td>
									<td>@tickets.Ans_Date</td>
									@if (tickets.Status != "Pending")
									{
										<form asp-action="SendReply">
										<td><input name="ticket_id" type="hidden" value="@tickets.Id" /><button type="submit" class="btn btn-sm btn-send-message"><i class="fa fa-reply"></i> Reply</button></td>
										</form>
									}
									else
									{
										<td></td>
									}
								</tr>
							</tbody>
						}
					</table>
		</div>
	</div>
	</div>
	</div>
	</div>