@model IEnumerable<RaiseTickets>
@if(Model != null)
{
foreach (var tickets in Model)
{
	
				

			<div class="widget-body">
				<div class="widget-main no-padding">
					<table class="table table-bordered table-striped">
						<thead class="thin-border-bottom">
							<tr>
								<th>
									<i class="ace-icon fa fa-caret-right blue"></i>Emp
								</th>

								<th>
									<i class="ace-icon fa fa-caret-right blue"></i>Status
								</th>

								<th class="hidden-480">
									<i class="ace-icon fa fa-caret-right blue"></i>Date
								</th>
							</tr>
						</thead>

						<tbody>
							<tr>
								<td>@tickets.Employee_Id</td>

								<td>
									<span class="label label-inverse arrowed-right arrowed-in">@tickets.Status</span>
								</td>

								<td class="hidden-480">
									@tickets.Created_On
								</td>
							</tr>

							
						</tbody>
					</table>
				</div><!-- /.widget-main -->
		<!-- /.col -->
		</div>

	}
}
else
{
	<div class="widget-body">
				<div class="widget-main no-padding">
	<p>You Don't have Unawswer Task </p>
	</div>
	</div>
}