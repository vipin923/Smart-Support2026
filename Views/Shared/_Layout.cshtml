	<script type="text/javascript">
			"use strict";

				// Build the connection
						const connection = new signalR.HubConnectionBuilder()
					.withUrl("/notificationHub")
					.configureLogging(signalR.LogLevel.Information)
					.build();

				connection.on("ReceiveNotification", (message) => {
		// Handle the incoming notification message (e.g., display a pop-up)
				 toastr.success(message);
				 countNotify();
				 readMessage();

		});

			connection.on("ReceiveNotify", (model) => {
				const list = document.getElementById("notificationList");
		list.innerHTML = ""; // Clear existing
		model.forEach(msg => {
			const li = document.createElement("li");
							li.textContent = `${msg.message}`;
			list.appendChild(li);
			document.getElementById("myButton").addEventListener("click", function() {

				markAllAsRead(msg.id);
				countNotify();

			});
		});
			});
		 connection.on("ReceiveCount",(count) =>{
						const spam = document.getElementById("notifyCount");
						spam.innerText = count;

				});


		async function start() {
					try {
						await connection.start();
						console.log("SignalR Connected.");
						countNotify();
						readMessage();


					} catch (err) {
						console.error(err.toString());
					}
				};
			async function readMessage(){
						connection.invoke("GetNotification").catch(err => console.error(err.toString()));

		}
		async function countNotify(){
			connection.invoke("GetNotifyCount").catch(err => console.error(err.toString()));

		}
		async function markAllAsRead(Id) {

					connection.invoke("MarkAsRead",Id).catch(err => console.error(err.toString()));
		}
			async function humanizeDate(date) {
		  const now = new Date();
		  const differenceInSeconds = Math.floor((date - now) / 1000);

		  const minutes = Math.floor(differenceInSeconds / 60);
		  const hours = Math.floor(minutes / 60);
		  const days = Math.floor(hours / 24);
		  const months = Math.floor(days / 30); // Approximate
		  const years = Math.floor(months / 12); // Approximate

		  const rtf = new Intl.RelativeTimeFormat('en', { numeric: 'auto' });

		  if (Math.abs(years) > 0) {
			return rtf.format(years, 'year');
		  } else if (Math.abs(months) > 0) {
			return rtf.format(months, 'month');
		  } else if (Math.abs(days) > 0) {
			return rtf.format(days, 'day');
		  } else if (Math.abs(hours) > 0) {
			return rtf.format(hours, 'hour');
		  } else if (Math.abs(minutes) > 0) {
			return rtf.format(minutes, 'minute');
		  } else {
			return rtf.format(differenceInSeconds, 'second');
		  }
		}


		start();
	</script>
